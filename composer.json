{
    "name": "adamt/code-wars",
    "config": {
        "platform": {
            "php": "8.1"
        }
    },
    "autoload": {
        "psr-4": {
            "Kata\\": "Kata/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Y2026\\": "Tests/"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0"
    },
    "scripts": {
        "unit": "phpunit --colors=always",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "stan": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "ready": [
            "@cs",
            "@stan",
            "@unit"
        ]
    }
}
